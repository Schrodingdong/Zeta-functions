{
    "apiVersion": "autoscaling/v2",
    "kind": "HorizontalPodAutoscaler",
    "metadata": {
        "name": "%ZETA_NAME%",
        "namespace": "%ZETA_NAMESPACE%"
    },
    "spec": {
        "minReplicas": 1,
        "maxReplicas": 10,
        "scaleTargetRef": {
            "apiVersion": "apps/v1",
            "kind": "Deployment",
            "name": "%ZETA_NAME%"
        },
        "metrics": [
            {
                "resource": {
                    "name": "cpu",
                    "target": {
                        "averageUtilization": 60,
                        "type": "Utilization"
                    }
                },
                "type": "Resource"
            },
            {
                "resource": {
                    "name": "memory",
                    "target": {
                        "averageUtilization": 80,
                        "type": "Utilization"
                    }
                },
                "type": "Resource"
            }
        ]
    }
}
